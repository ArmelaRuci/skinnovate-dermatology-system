# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
build/
.eggs/
.venv/
venv/
env/

# ── Flask ─────────────────────────────────────────────────────────────────────
instance/
*.db
*.sqlite3

# Uploads folder — keep the folder, ignore the actual uploaded files
backend/uploads/*
!backend/uploads/.gitkeep

# ── Database migrations — keep folder + base files, ignore auto-generated versions
backend/migrations/versions/

# ── AI model weights (large binary files — store in cloud/drive, not git) ─────
*.h5
*.keras
*.pb
*.pt
*.ckpt
*.tflite
backend/app/services/ai_service/model/*
!backend/app/services/ai_service/model/.gitkeep

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
.vite/
*.local
frontend/dist/

# ── Environment files — NEVER commit real .env files ─────────────────────────
.env
*.env
backend/.env
frontend/.env
# But DO commit the examples:
!.env.example
!backend/.env.example
!frontend/.env.example

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
